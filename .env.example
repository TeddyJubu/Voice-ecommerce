# ─── LLM Providers ──────────────────────────────────────────────────────────
VITE_CEREBRAS_API_KEY=
VITE_CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
VITE_CEREBRAS_MODEL=gpt-oss-120b

VITE_NEBIUS_API_KEY=
VITE_NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
VITE_NEBIUS_MODEL=Qwen/Qwen2.5-72B-Instruct-fast

# ─── Speech-to-Text ─────────────────────────────────────────────────────────
VITE_GROQ_API_KEY=
VITE_GROQ_BASE_URL=https://api.groq.com/openai/v1
VITE_GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ─── Text-to-Speech (ElevenLabs) ────────────────────────────────────────────
# IMPORTANT: Do NOT prefix this with VITE_ — that would embed the key in the
# client bundle and make it extractable from the browser.  The Vite dev-server
# proxy (vite.config.ts) reads this server-side and injects it as xi-api-key
# before forwarding /api/tts requests to ElevenLabs.  For production, add a
# server route or serverless function that performs the same injection.
ELEVENLABS_API_KEY=

# Default voice (safe to expose — this is just a voice ID, not a secret).
# Pre-made ElevenLabs voice IDs:
#   Rachel  21m00Tcm4TlvDq8ikWAM  — Neutral, balanced (default)
#   Josh    TxGEqnHWrfWFTfGW9XjX  — Warm, conversational
#   Dorothy ThT5KcBeYPX3keUQqHPh  — Expressive, storytelling
#   Bella   EXAVITQu4vr4xnSDxMaL  — Bright, energetic
#   Elli    MF3mGyEYCl7XYWbV9V6O  — Calm, soothing
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── Optional ────────────────────────────────────────────────────────────────
VITE_DEEPGRAM_API_KEY=
VITE_STT_PROVIDER=elevenlabs
VITE_LLM_PRIMARY=cerebras
VITE_CEREBRAS_AVAILABILITY_THRESHOLD=0.9
